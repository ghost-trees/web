# Default: normalize to LF in the repo
*           text=auto eol=lf

# Windows-native scripts/tools may want CRLF in working tree
*.bat       eol=crlf
*.cmd       eol=crlf
*.ps1       eol=crlf

# Explicit LF for Unix-y files
*.sh        eol=lf

# Binary files (never touch line endings)
*.png       binary
*.jpg       binary
*.gif       binary
*.pdf       binary
*.zip       binary